# The Arkwright Method — landing page env vars
#
# Copy to .env.local for development, or set in Railway's Variables tab for prod.

# --- Site identity ---
NEXT_PUBLIC_SITE_URL=https://arkwrightmethod.com

# --- Database (Railway Postgres) ---
# Provided by Railway. For local dev, point at a local Postgres or Railway's public URL.
DATABASE_URL=

# --- Analytics (optional, wired in Phase 6) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Email capture (optional, pick one) ---
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=
# BEEHIIV_API_KEY=
# MAILCHIMP_API_KEY=

# --- Commerce (optional) ---
# AMAZON_AFFILIATE_TAG=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# --- Review-for-reward funnel ---
# The secret injected into the in-book QR URL (https://.../resena?k=<secret>).
# Required — /resena is silently hidden until this matches.
REVIEW_QR_SECRET=
# Amazon.es listing URL for The Arkwright Method. Leave empty until the
# listing is live — the UI degrades gracefully to "Coming soon on Amazon".
REVIEW_AMAZON_URL=

# --- Contacts dashboard ---
# Token that gates /admin and /api/admin/contacts.csv. Required — without
# it the dashboard returns 401 to every request (fail-closed).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_EXPORT_TOKEN=

# --- Reward delivery (optional external URLs) ---
# When set, /api/reward/<kind> 302-redirects to these URLs instead of
# streaming a file from private/rewards/. Use for files too large to
# commit to git (e.g. a 5-hour audiobook hosted as a GitHub Release
# asset). Filesystem stays the default; URLs only override per kind.
REWARD_EBOOK_URL=
REWARD_AUDIO_URL=

# --- Stripe (digital offer · 12€ ebook + audiobook) ---
# All four together gate the checkout. While they're empty,
# /api/checkout returns 503 and the landing CTA shows
# "Próximamente disponible". Setting them flips the funnel ON
# without any code change.
#   1. Create the product in Stripe Dashboard (or via API):
#        Product: "The Arkwright Method · ebook + audiobook"
#        Price:   1200 EUR cents, one-time
#   2. Configure a Webhook endpoint:
#        URL: https://arkwright.laralawn.com/api/stripe/webhook
#        Events: checkout.session.completed, charge.refunded
#   3. Paste the values below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_OFFER_12EUR=

# --- Digital product asset URLs (served from /biblioteca) ---
# Same pattern as REWARD_*: empty → /api/biblioteca/<file> returns 503
# and the library card shows "Próximamente disponible". The audio URL
# is the existing GitHub Release asset; the ebook URL stays empty
# until the file is uploaded.
PRODUCT_EBOOK_URL=
PRODUCT_AUDIO_URL=https://github.com/thisisbeckinreallife-cloud/Libro-nuevo-/releases/download/products-arkwright-audio-es-v1/audiolibro_arkwright.m4b

# Optional: alternative zip with the 17 individual MP3 chapters. Shown
# as a secondary download in /biblioteca for users whose device can't
# open .m4b (rare — mostly older Windows / Linux without an audiobook
# reader).
PRODUCT_AUDIO_MP3_ZIP_URL=https://github.com/thisisbeckinreallife-cloud/Libro-nuevo-/releases/download/products-arkwright-audio-es-v1/arkwright-audiolibro-mp3s.zip

# Base URL for per-chapter MP3 assets used by the embedded web audio
# player (/api/biblioteca/stream/[chapter]). Defaults to the GitHub
# release if unset. Override here when migrating to R2 / S3 — only
# this var needs to change.
# PRODUCT_AUDIO_CHAPTERS_BASE_URL=

# Transactional email (Resend). When set, /api/stripe/webhook sends a
# purchase confirmation with the biblioteca link, direct downloads and
# the "Cómo escucharlo" guide. Leave empty to disable email (the
# webhook continues working, just without notifications).
RESEND_API_KEY=
# Optional: from-address override. Defaults to "Arkwright <hola@laralawn.com>"
# RESEND_FROM=
