# The Arkwright Method — landing page env vars
#
# Copy to .env.local for development, or set in Railway's Variables tab for prod.

# --- Site identity ---
NEXT_PUBLIC_SITE_URL=https://arkwrightmethod.com

# --- Database (Railway Postgres) ---
# Provided by Railway. For local dev, point at a local Postgres or Railway's public URL.
DATABASE_URL=

# --- Analytics (optional, wired in Phase 6) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Email capture (optional, pick one) ---
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=
# BEEHIIV_API_KEY=
# MAILCHIMP_API_KEY=

# --- Commerce (optional) ---
# AMAZON_AFFILIATE_TAG=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# --- Review-for-reward funnel ---
# The secret injected into the in-book QR URL (https://.../resena?k=<secret>).
# Required — /resena is silently hidden until this matches.
REVIEW_QR_SECRET=
# Amazon.es listing URL for The Arkwright Method. Leave empty until the
# listing is live — the UI degrades gracefully to "Coming soon on Amazon".
REVIEW_AMAZON_URL=

# --- Contacts dashboard ---
# Token that gates /admin and /api/admin/contacts.csv. Required — without
# it the dashboard returns 401 to every request (fail-closed).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_EXPORT_TOKEN=
