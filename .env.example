# The Arkwright Method — landing page env vars
#
# Copy to .env.local for development, or set in Railway's Variables tab for prod.
# Nothing here is required for the current build; values below are placeholders
# for integrations mentioned in docs/design-handoff/README.md (GA4, ConvertKit, Amazon affiliate, etc.)
# that the dev is expected to wire up before launch.

# --- Site identity ---
NEXT_PUBLIC_SITE_URL=https://arkwrightmethod.com

# --- Analytics (optional) ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Email capture (optional, pick one) ---
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=
# BEEHIIV_API_KEY=
# MAILCHIMP_API_KEY=

# --- Commerce (optional) ---
# AMAZON_AFFILIATE_TAG=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
