// Prisma schema — Arkwright Method

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BonusTokenStatus {
  unissued
  claimed
  revoked
}

model BonusToken {
  id         String           @id @default(uuid()) @db.Uuid
  token      String           @unique
  status     BonusTokenStatus @default(unissued)
  bookLot    String?          @map("book_lot")
  createdAt  DateTime         @default(now()) @map("created_at")
  claimedAt  DateTime?        @map("claimed_at")

  claim      Claim?

  @@map("bonus_tokens")
}

model CounterCache {
  id            Int      @id @default(1)
  claimedCount  Int      @default(0) @map("claimed_count")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("counter_cache")
}

model User {
  id        String          @id @default(uuid()) @db.Uuid
  email     String          @unique
  name      String?
  createdAt DateTime        @default(now()) @map("created_at")

  claim     Claim?
  sessions  Session[]
  entries   WorkbookEntry[]

  @@map("users")
}

model Claim {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  tokenId   String     @unique @map("token_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     BonusToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@map("claims")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  secretHash String   @unique @map("secret_hash")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model WorkbookEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  section   String
  fieldId   String   @map("field_id")
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, section, fieldId])
  @@index([userId, section])
  @@map("workbook_entries")
}

enum ReviewStatus {
  submitted
  approved
  rejected
}

// Review-for-reward funnel.
// Reader scans in-book QR → lands on /resena → writes Amazon review →
// uploads screenshot → this row is created → claim token lets them
// download the ebook + audio rewards. No cap — open to every buyer.
model ReviewSubmission {
  id             String       @id @default(uuid()) @db.Uuid
  email          String?
  status         ReviewStatus @default(submitted)
  screenshot     Bytes
  contentType    String       @map("content_type")
  screenshotHash String       @map("screenshot_hash")
  ipHash         String       @map("ip_hash")
  userAgent      String?      @map("user_agent")
  claimToken     String       @unique @map("claim_token")
  ebookDownloads Int          @default(0) @map("ebook_downloads")
  audioDownloads Int          @default(0) @map("audio_downloads")
  claimedAt      DateTime?    @map("claimed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([ipHash, createdAt])
  @@index([screenshotHash])
  @@map("review_submissions")
}

// Unified marketing contacts table.
// Filled automatically every time someone leaves their email (workbook
// signup, review submission, future CTAs). Idempotent by email — repeat
// touches just update `lastSeenAt` and append the new source.
//
// Source of truth for email marketing. Export to CSV via /admin to feed
// Resend audiences, Meta Ads custom audiences, or anything else.
//
// Independent from `User` and `ReviewSubmission` so we can include people
// who never finished those flows AND so deletion requests on this table
// don't cascade into the workbook session model.
model Contact {
  id                String   @id @default(uuid()) @db.Uuid
  email             String   @unique
  name              String?
  // First touchpoint — kept stable so we know the original CTA.
  firstSource       String   @map("first_source")
  // Latest touchpoint — overwritten on every upsert. Useful when the
  // same person enters via multiple flows.
  lastSource        String   @map("last_source")
  // Comma-separated set of every source seen ("workbook,resena").
  // Cheap segmentation without a join table.
  sources           String   @default("")
  lang              String   @default("es")
  consentMarketing  Boolean  @default(true) @map("consent_marketing")
  meta              Json?
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime @default(now()) @updatedAt @map("last_seen_at")

  @@index([firstSeenAt])
  @@index([lastSource])
  @@index([lang])
  @@map("contacts")
}
