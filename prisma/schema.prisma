// Prisma schema — Arkwright Method

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BonusTokenStatus {
  unissued
  claimed
  revoked
}

model BonusToken {
  id         String           @id @default(uuid()) @db.Uuid
  token      String           @unique
  status     BonusTokenStatus @default(unissued)
  bookLot    String?          @map("book_lot")
  createdAt  DateTime         @default(now()) @map("created_at")
  claimedAt  DateTime?        @map("claimed_at")

  claim      Claim?

  @@map("bonus_tokens")
}

model CounterCache {
  id            Int      @id @default(1)
  claimedCount  Int      @default(0) @map("claimed_count")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("counter_cache")
}

model User {
  id        String          @id @default(uuid()) @db.Uuid
  email     String          @unique
  name      String?
  createdAt DateTime        @default(now()) @map("created_at")

  claim     Claim?
  sessions  Session[]
  entries   WorkbookEntry[]

  @@map("users")
}

model Claim {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  tokenId   String     @unique @map("token_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     BonusToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@map("claims")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  secretHash String   @unique @map("secret_hash")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model WorkbookEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  section   String
  fieldId   String   @map("field_id")
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, section, fieldId])
  @@index([userId, section])
  @@map("workbook_entries")
}

enum ReviewStatus {
  submitted
  approved
  rejected
}

// Review-for-reward funnel.
// Reader scans in-book QR → lands on /resena → writes Amazon review →
// uploads screenshot → this row is created → claim token lets them
// download the ebook + audio rewards. No cap — open to every buyer.
model ReviewSubmission {
  id             String       @id @default(uuid()) @db.Uuid
  email          String?
  status         ReviewStatus @default(submitted)
  screenshot     Bytes
  contentType    String       @map("content_type")
  screenshotHash String       @map("screenshot_hash")
  ipHash         String       @map("ip_hash")
  userAgent      String?      @map("user_agent")
  claimToken     String       @unique @map("claim_token")
  ebookDownloads Int          @default(0) @map("ebook_downloads")
  audioDownloads Int          @default(0) @map("audio_downloads")
  claimedAt      DateTime?    @map("claimed_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([ipHash, createdAt])
  @@index([screenshotHash])
  @@map("review_submissions")
}

enum PurchaseStatus {
  pending
  paid
  refunded
  failed
}

// One-time digital purchases — Stripe Checkout.
//
// Created by the Stripe webhook on `checkout.session.completed` and
// looked up by either `stripeSessionId` (post-redirect from Stripe) or
// `accessToken` (the secret key the buyer keeps in their bookmark to
// re-enter /biblioteca later).
//
// Idempotency: the webhook upserts by `stripeSessionId` so duplicate
// deliveries from Stripe never create double rows.
//
// `accessToken` is a UUID v4 — long enough that brute-forcing one is
// pointless; treated as a bearer secret in URLs (same model that
// SaaS share-links and email magic-links use).
model Purchase {
  id                    String         @id @default(uuid()) @db.Uuid
  email                 String
  name                  String?
  stripeSessionId       String         @unique @map("stripe_session_id")
  stripePaymentIntentId String?        @unique @map("stripe_payment_intent_id")
  amount                Int            // in cents
  currency              String         @default("eur")
  status                PurchaseStatus @default(pending)
  // The secret URL key — opaque to the user, never logged or exposed.
  accessToken           String         @unique @map("access_token")
  ebookDownloads        Int            @default(0) @map("ebook_downloads")
  audioDownloads        Int            @default(0) @map("audio_downloads")
  lang                  String         @default("es")
  meta                  Json?          // raw Stripe payload snapshot for audit
  createdAt             DateTime       @default(now()) @map("created_at")
  paidAt                DateTime?      @map("paid_at")
  refundedAt            DateTime?      @map("refunded_at")

  @@index([email])
  @@index([status, createdAt])
  @@map("purchases")
}

// Waitlist for the not-yet-shipping editions of the book (signed paperback,
// numbered collector). Submitted from /oferta when someone clicks an
// "Reserve my spot" CTA. We never charge for these — just collect the
// email so we can email the buyer the moment that edition opens. Also
// upserts into `Contact` so marketing can segment from the same table.
model WaitlistEntry {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  // "paperback" | "collector" — keeps the two editions countable separately.
  tier      String
  lang      String   @default("es")
  // The page or campaign source — useful if we ever run paid waitlist ads.
  source    String?
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, tier])
  @@index([tier, createdAt])
  @@map("waitlist_entries")
}

// Unified marketing contacts table.
// Filled automatically every time someone leaves their email (workbook
// signup, review submission, future CTAs). Idempotent by email — repeat
// touches just update `lastSeenAt` and append the new source.
//
// Source of truth for email marketing. Export to CSV via /admin to feed
// Resend audiences, Meta Ads custom audiences, or anything else.
//
// Independent from `User` and `ReviewSubmission` so we can include people
// who never finished those flows AND so deletion requests on this table
// don't cascade into the workbook session model.
model Contact {
  id                String   @id @default(uuid()) @db.Uuid
  email             String   @unique
  name              String?
  // First touchpoint — kept stable so we know the original CTA.
  firstSource       String   @map("first_source")
  // Latest touchpoint — overwritten on every upsert. Useful when the
  // same person enters via multiple flows.
  lastSource        String   @map("last_source")
  // Comma-separated set of every source seen ("workbook,resena").
  // Cheap segmentation without a join table.
  sources           String   @default("")
  lang              String   @default("es")
  consentMarketing  Boolean  @default(true) @map("consent_marketing")
  meta              Json?
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime @default(now()) @updatedAt @map("last_seen_at")

  @@index([firstSeenAt])
  @@index([lastSource])
  @@index([lang])
  @@map("contacts")
}
