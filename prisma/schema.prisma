// Prisma schema — Arkwright Method

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BonusTokenStatus {
  unissued
  claimed
  revoked
}

model BonusToken {
  id         String           @id @default(uuid()) @db.Uuid
  token      String           @unique
  status     BonusTokenStatus @default(unissued)
  bookLot    String?          @map("book_lot")
  createdAt  DateTime         @default(now()) @map("created_at")
  claimedAt  DateTime?        @map("claimed_at")

  claim      Claim?

  @@map("bonus_tokens")
}

model CounterCache {
  id            Int      @id @default(1)
  claimedCount  Int      @default(0) @map("claimed_count")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("counter_cache")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now()) @map("created_at")

  claim     Claim?
  sessions  Session[]

  @@map("users")
}

model Claim {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @map("user_id") @db.Uuid
  tokenId   String     @unique @map("token_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     BonusToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@map("claims")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  secretHash String   @unique @map("secret_hash")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
